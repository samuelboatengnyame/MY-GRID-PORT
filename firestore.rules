rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resourceData) {
      return isSignedIn() && (resourceData.get('ownerId', '') == request.auth.uid || resourceData.get('userId', '') == request.auth.uid);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // --- Entity Validations ---

    function isValidPhoto(data) {
      return data.keys().hasAll(['url', 'userId', 'createdAt', 'width', 'height', 'albumId']) &&
             data.keys().size() <= 12 &&
             data.url is string && data.url.size() < 1048488 &&
             data.userId == request.auth.uid &&
             data.width is number && data.height is number &&
             (data.get('title', '') is string) &&
             (data.get('description', '') is string) &&
             (data.albumId == null || (data.albumId is string && isValidId(data.albumId))) &&
             (data.get('isFavorite', false) is bool);
    }

    function isAlbumOwner(albumId) {
      return albumId == null || get(/databases/$(database)/documents/albums/$(albumId)).data.ownerId == request.auth.uid;
    }

    function isValidAlbum(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             (data.get('description', '') is string && data.get('description', '').size() <= 500) &&
             (data.get('coverPhotoUrl', '') is string);
    }

    // --- Collection Rules ---

    match /photos/{photoId} {
      allow get: if isOwner(resource.data);
      allow list: if isOwner(resource.data);
      
      allow create: if isSignedIn() && 
                    isValidId(photoId) && 
                    isValidPhoto(incoming()) && 
                    incoming().createdAt == request.time &&
                    isAlbumOwner(incoming().albumId);
      
      allow update: if isOwner(resource.data) && 
                    isValidPhoto(incoming()) && 
                    (incoming().get('userId', '') == resource.data.get('userId', '') || incoming().get('userId', '') == '') &&
                    (incoming().get('ownerId', '') == resource.data.get('ownerId', '') || incoming().get('ownerId', '') == '') &&
                    incoming().createdAt == resource.data.createdAt &&
                    incoming().updatedAt == request.time &&
                    isAlbumOwner(incoming().albumId) &&
                    (
                      incoming().diff(resource.data).affectedKeys().hasAny(['title', 'description', 'updatedAt', 'albumId', 'isFavorite'])
                    );
      
      allow delete: if isOwner(resource.data);
    }

    match /albums/{albumId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      allow create: if isSignedIn() && 
                    isValidId(albumId) && 
                    isValidAlbum(incoming()) && 
                    incoming().createdAt == request.time;

      allow update: if isOwner(existing()) && 
                    isValidAlbum(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    (
                      incoming().diff(existing()).affectedKeys().hasAny(['name', 'description', 'coverPhotoUrl'])
                    );

      allow delete: if isOwner(existing());
    }

    match /users/{userId} {
      allow get, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
